# Porta exposta no host
PORT=3000

# Senha do painel do organizador (/admin.html) — TROQUE antes de subir!
ADMIN_PASSWORD=navecon2026

# Fuso usado nos prazos
TZ=America/Sao_Paulo

# Diretório de dados (já definido no container, normalmente não precisa mexer)
# DATA_DIR=/app/data

# Atualização ao vivo de placar/marcadores.
# Provedor: worldcup2026 (grátis, cobre a Copa 2026) | apifootball | none
LIVE_PROVIDER=worldcup2026

# (Opcional) Só necessário se LIVE_PROVIDER=apifootball (api-sports.io, plano pago p/ 2026).
# API_FOOTBALL_KEY=sua_chave_aqui
